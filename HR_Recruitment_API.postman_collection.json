{
  "info": {
    "name": "HR Recruitment System API",
    "description": "Complete API documentation for the HR Recruitment System. Set `baseUrl` to your server (e.g. http://localhost:5000) and `authToken` after login.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000", "type": "string" },
    { "key": "authToken", "value": "", "type": "string" }
  ],
  "item": [

    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "exec": ["const r = pm.response.json();", "if (r.data?.accessToken) pm.collectionVariables.set('authToken', r.data.accessToken);"], "type": "text/javascript" } }],
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"superadmin@hrapp.com\",\n  \"password\": \"Admin@123\"\n}" }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/auth/logout",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }]
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/auth/refresh",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{}" }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET", "url": "{{baseUrl}}/api/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }]
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/auth/forgot-password",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"user@example.com\"\n}" }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/auth/reset-password",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"token\": \"<reset_token_from_email>\",\n  \"password\": \"NewPassword@123\"\n}" }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/auth/change-password",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"currentPassword\": \"OldPass@123\",\n  \"newPassword\": \"NewPass@123\"\n}" }
          }
        }
      ]
    },

    {
      "name": "📊 Dashboard",
      "item": [
        {
          "name": "Get Stats",
          "request": {
            "method": "GET", "url": "{{baseUrl}}/api/dashboard/stats",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }]
          }
        },
        {
          "name": "Recruitment Chart",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/dashboard/recruitment-chart?period=6M", "host": ["{{baseUrl}}"], "path": ["api","dashboard","recruitment-chart"], "query": [{ "key": "period", "value": "6M", "description": "6M or 12M" }] },
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }]
          }
        },
        {
          "name": "Revenue Chart",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/dashboard/revenue-chart?period=6M", "host": ["{{baseUrl}}"], "path": ["api","dashboard","revenue-chart"], "query": [{ "key": "period", "value": "6M" }] },
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }]
          }
        }
      ]
    },

    {
      "name": "📄 CV Database",
      "item": [
        {
          "name": "List Candidates",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/cv?page=1&limit=10&search=&gender=&status=&isPriority=&minExp=&maxExp=&minCTC=&maxCTC=&location=&qualification=&sortBy=createdAt&sortDir=desc",
              "host": ["{{baseUrl}}"], "path": ["api","cv"],
              "query": [
                { "key": "page", "value": "1" }, { "key": "limit", "value": "10" },
                { "key": "search", "value": "", "description": "Searches name, email, skills, designation, company, AND full PDF text" },
                { "key": "gender", "value": "", "description": "MALE | FEMALE | OTHER" },
                { "key": "status", "value": "", "description": "NEW | ACTIVE | SHORTLISTED | PLACED | REJECTED" },
                { "key": "isPriority", "value": "" }, { "key": "minExp", "value": "" }, { "key": "maxExp", "value": "" },
                { "key": "minCTC", "value": "" }, { "key": "maxCTC", "value": "" },
                { "key": "location", "value": "" }, { "key": "qualification", "value": "" },
                { "key": "sortBy", "value": "createdAt" }, { "key": "sortDir", "value": "desc" }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }]
          }
        },
        {
          "name": "Get Candidate by ID",
          "request": {
            "method": "GET", "url": "{{baseUrl}}/api/cv/:id",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }]
          }
        },
        {
          "name": "Create Candidate (with CV file)",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/cv",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "firstName", "value": "John", "type": "text" },
                { "key": "lastName", "value": "Doe", "type": "text" },
                { "key": "email", "value": "john.doe@example.com", "type": "text" },
                { "key": "phone", "value": "9876543210", "type": "text" },
                { "key": "gender", "value": "MALE", "type": "text" },
                { "key": "currentDesignation", "value": "Software Engineer", "type": "text" },
                { "key": "currentCompany", "value": "TechCorp", "type": "text" },
                { "key": "totalExperience", "value": "5", "type": "text" },
                { "key": "currentCTC", "value": "800000", "type": "text" },
                { "key": "expectedCTC", "value": "1000000", "type": "text" },
                { "key": "noticePeriod", "value": "30", "type": "text" },
                { "key": "currentLocation", "value": "Mumbai", "type": "text" },
                { "key": "highestQualification", "value": "B.Tech", "type": "text" },
                { "key": "skills", "value": "[\"React\",\"Node.js\",\"TypeScript\"]", "type": "text" },
                { "key": "technologyStack", "value": "[\"MERN\",\"AWS\"]", "type": "text" },
                { "key": "status", "value": "NEW", "type": "text" },
                { "key": "source", "value": "LinkedIn", "type": "text" },
                { "key": "cvFile", "type": "file", "src": "", "description": "PDF or DOCX file (max 10MB). Raw text auto-extracted for search." }
              ]
            }
          }
        },
        {
          "name": "Update Candidate",
          "request": {
            "method": "PUT", "url": "{{baseUrl}}/api/cv/:id",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "firstName", "value": "John", "type": "text" },
                { "key": "currentCTC", "value": "900000", "type": "text" },
                { "key": "cvFile", "type": "file", "src": "", "description": "Optional — replaces existing CV file" }
              ]
            }
          }
        },
        {
          "name": "Delete Candidate",
          "request": {
            "method": "DELETE", "url": "{{baseUrl}}/api/cv/:id",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }]
          }
        },
        {
          "name": "Toggle Priority",
          "request": {
            "method": "PATCH", "url": "{{baseUrl}}/api/cv/:id/priority",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }]
          }
        },
        {
          "name": "Update Custom Fields",
          "request": {
            "method": "PATCH", "url": "{{baseUrl}}/api/cv/:id/custom-fields",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"fieldName\": \"referred_by\",\n  \"value\": \"HR Team\"\n}" }
          }
        },
        {
          "name": "Download CV File",
          "request": {
            "method": "GET", "url": "{{baseUrl}}/api/cv/:id/download",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }]
          }
        },
        {
          "name": "Bulk Import CVs",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/cv/bulk-import",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "files", "type": "file", "src": "", "description": "Upload multiple PDF/DOCX files (max 50 at once). AI parses each CV and raw text is stored for search." }
              ]
            }
          }
        },
        {
          "name": "Get Bulk Import Status",
          "request": {
            "method": "GET", "url": "{{baseUrl}}/api/cv/bulk-status/:jobId",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }]
          }
        }
      ]
    },

    {
      "name": "💼 Job Openings",
      "item": [
        {
          "name": "List Jobs",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/jobs?page=1&limit=10&search=&status=&clientId=&sortBy=createdAt&sortDir=desc",
              "host": ["{{baseUrl}}"], "path": ["api","jobs"],
              "query": [
                { "key": "page", "value": "1" }, { "key": "limit", "value": "10" },
                { "key": "search", "value": "" }, { "key": "status", "value": "" },
                { "key": "clientId", "value": "" }, { "key": "sortBy", "value": "createdAt" }, { "key": "sortDir", "value": "desc" }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }]
          }
        },
        {
          "name": "Get Job by ID",
          "request": {
            "method": "GET", "url": "{{baseUrl}}/api/jobs/:id",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }]
          }
        },
        {
          "name": "Create Job",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/jobs",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "jobTitle", "value": "Senior React Developer", "type": "text" },
                { "key": "clientId", "value": "<client_id>", "type": "text" },
                { "key": "location", "value": "Mumbai", "type": "text" },
                { "key": "jobType", "value": "FULL_TIME", "type": "text" },
                { "key": "experienceMin", "value": "3", "type": "text" },
                { "key": "experienceMax", "value": "7", "type": "text" },
                { "key": "ctcMin", "value": "800000", "type": "text" },
                { "key": "ctcMax", "value": "1500000", "type": "text" },
                { "key": "numberOfOpenings", "value": "2", "type": "text" },
                { "key": "description", "value": "Looking for a senior React developer...", "type": "text" },
                { "key": "skills", "value": "[\"React\",\"TypeScript\",\"Node.js\"]", "type": "text" },
                { "key": "status", "value": "OPEN", "type": "text" },
                { "key": "jdDocument", "type": "file", "src": "", "description": "Optional JD PDF" }
              ]
            }
          }
        },
        {
          "name": "Update Job",
          "request": {
            "method": "PUT", "url": "{{baseUrl}}/api/jobs/:id",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "jobTitle", "value": "Lead React Developer", "type": "text" },
                { "key": "status", "value": "OPEN", "type": "text" }
              ]
            }
          }
        },
        {
          "name": "Delete Job",
          "request": {
            "method": "DELETE", "url": "{{baseUrl}}/api/jobs/:id",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }]
          }
        },
        {
          "name": "Duplicate Job",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/jobs/:id/duplicate",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }]
          }
        },
        {
          "name": "Close Job",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/jobs/:id/close",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }]
          }
        },
        {
          "name": "Toggle Assignee",
          "request": {
            "method": "PATCH", "url": "{{baseUrl}}/api/jobs/:id/assignees",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"userId\": \"<user_id>\"\n}" }
          }
        },
        {
          "name": "Import Jobs CSV",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/jobs/import-csv",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "body": { "mode": "formdata", "formdata": [{ "key": "file", "type": "file", "src": "" }] }
          }
        },
        {
          "name": "Update Custom Fields",
          "request": {
            "method": "PATCH", "url": "{{baseUrl}}/api/jobs/:id/custom-fields",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"fieldName\": \"priority_level\",\n  \"value\": \"High\"\n}" }
          }
        },
        {
          "name": "Start Replacement",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/jobs/:id/start-replacement",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"reason\": \"Candidate resigned\"\n}" }
          }
        },
        {
          "name": "Update PSR Columns",
          "request": {
            "method": "PATCH", "url": "{{baseUrl}}/api/jobs/:id/psr-columns",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"columns\": [\"joiningDate\", \"salary\", \"offerStatus\"]\n}" }
          }
        },
        {
          "name": "Update Post-Selection Record",
          "request": {
            "method": "PATCH", "url": "{{baseUrl}}/api/jobs/psr/:recordId",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"joiningDate\": \"2026-06-01\",\n  \"offeredSalary\": 900000\n}" }
          }
        },
        {
          "name": "Upload Offer Letter",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/jobs/psr/:recordId/offer-letter",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "body": { "mode": "formdata", "formdata": [{ "key": "offerLetter", "type": "file", "src": "" }] }
          }
        },
        {
          "name": "Add Interview Round",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/jobs/:id/rounds",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Technical Round 1\"\n}" }
          }
        },
        {
          "name": "Rename Round",
          "request": {
            "method": "PATCH", "url": "{{baseUrl}}/api/jobs/rounds/:roundId",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"HR Round\"\n}" }
          }
        },
        {
          "name": "Update Round Columns",
          "request": {
            "method": "PATCH", "url": "{{baseUrl}}/api/jobs/rounds/:roundId/columns",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"columns\": [\"interviewDate\", \"feedback\", \"result\"]\n}" }
          }
        },
        {
          "name": "Add Candidate to Round",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/jobs/rounds/:roundId/candidates",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"candidateId\": \"<candidate_id>\"\n}" }
          }
        },
        {
          "name": "Remove Candidate from Round",
          "request": {
            "method": "DELETE", "url": "{{baseUrl}}/api/jobs/rounds/:roundId/candidates/:candidateId",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }]
          }
        },
        {
          "name": "Update Interview Slot",
          "request": {
            "method": "PATCH", "url": "{{baseUrl}}/api/jobs/slots/:slotId",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"interviewDate\": \"2026-06-15\",\n  \"feedback\": \"Strong candidate\",\n  \"result\": \"SELECTED\"\n}" }
          }
        },
        {
          "name": "Update Slot Custom Field",
          "request": {
            "method": "PATCH", "url": "{{baseUrl}}/api/jobs/slots/:slotId/custom-fields",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"fieldName\": \"panel_name\",\n  \"value\": \"Rahul Sharma\"\n}" }
          }
        },
        {
          "name": "Bulk Update Slots",
          "request": {
            "method": "PATCH", "url": "{{baseUrl}}/api/jobs/rounds/:roundId/slots/bulk",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"updates\": [\n    { \"slotId\": \"<id>\", \"result\": \"SELECTED\" },\n    { \"slotId\": \"<id>\", \"result\": \"REJECTED\" }\n  ]\n}" }
          }
        }
      ]
    },

