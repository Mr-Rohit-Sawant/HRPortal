// ============================================================
// HR RECRUITMENT SYSTEM - PRISMA SCHEMA
// Database: MySQL (XAMPP)
// ============================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextIndex", "fullTextSearch"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  FREELANCE
  INTERNSHIP
}

enum JobStatus {
  ACTIVE
  CLOSED
  ON_HOLD
  DRAFT
}

enum JobPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum CandidateStatus {
  NEW
  SCREENING
  SHORTLISTED
  INTERVIEWING
  OFFERED
  HIRED
  REJECTED
  ON_HOLD
  ACTIVE
  INACTIVE
  HOLD
  BLACKLIST
}

enum InterviewStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  RESCHEDULED
}

enum RoundResult {
  PENDING
  SELECTED
  REJECTED
  ON_HOLD
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  IMPORT
  PASSWORD_CHANGE
  ROLE_CHANGE
  STATUS_CHANGE
}

enum ColumnDataType {
  STATUS
  DROPDOWN
  TEXT
  DATE
  EMPLOYEE
  CANDIDATES
  LOCATION
  FILES
  PRIORITY
  LABEL
  NUMBER
  CHECKBOX
  URL
  EMAIL
  PHONE
}

// ============================================================
// ROLES & PERMISSIONS
// ============================================================

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?  @db.Text
  isSystem    Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions RolePermission[]
  users       User[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  module      String
  action      String
  description String?
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]

  @@unique([module, action])
  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(uuid())
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

// ============================================================
// USERS & EMPLOYEES
// ============================================================

model User {
  id              String     @id @default(uuid())
  employeeId      String?    @unique
  email           String     @unique
  username        String     @unique
  passwordHash    String
  firstName       String
  lastName        String
  phone           String?
  profilePhoto    String?
  roleId          String
  department      String?
  designation     String?
  joiningDate     DateTime?
  salary          Decimal?   @db.Decimal(12, 2)
  address         String?    @db.Text
  city            String?
  state           String?
  country         String?    @default("India")
  status          UserStatus @default(ACTIVE)
  isSuperAdmin    Boolean    @default(false)
  twoFactorEnabled Boolean   @default(false)
  twoFactorSecret  String?
  lastLoginAt     DateTime?
  lastLoginIp     String?
  loginAttempts   Int        @default(0)
  lockedUntil     DateTime?
  passwordResetToken     String?
  passwordResetExpiresAt DateTime?
  refreshToken    String?    @db.Text
  notificationPrefs Json?
  customFields    Json?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  createdBy       String?

  role        Role         @relation(fields: [roleId], references: [id])
  auditLogs   AuditLog[]   @relation("UserAuditLogs")
  createdJobs JobOpening[] @relation("CreatedByUser")
  assignedJobs JobOpening[] @relation("AssignedToUser")
  invoices    Invoice[]    @relation("InvoiceCreatedBy")

  @@index([email])
  @@index([status])
  @@map("users")
}

// ============================================================
// CANDIDATES / CV DATABASE
// ============================================================

model Candidate {
  id                String          @id @default(uuid())
  firstName         String
  lastName          String
  email             String?
  phone             String?
  alternatePhone    String?
  gender            Gender?
  dateOfBirth       DateTime?
  profilePhoto      String?
  currentLocation   String?
  preferredLocations Json?
  religion          String?
  caste             String?
  languages         Json?
  nationality       String?         @default("Indian")

  // Professional Details
  currentDesignation String?
  currentCompany     String?
  totalExperience    Float?
  currentCTC         Decimal?       @db.Decimal(12, 2)
  expectedCTC        Decimal?       @db.Decimal(12, 2)
  noticePeriod       Int?
  currentlyEmployed  Boolean?       @default(true)

  // Location
  country         String?
  state           String?
  city            String?

  // Education
  highestQualification String?
  specialization       String?
  university           String?
  passingYear          Int?
  educationDetails     Json?

  // Experience
  experienceDetails    Json?

  // Skills & Certifications
  skills          Json?
  certifications  Json?
  technologyStack Json?
  keywords        Json?

  // Status & Meta
  status          CandidateStatus @default(NEW)
  isPriority      Boolean         @default(false)
  source          String?
  notes           String?         @db.Text
  cvFile          String?
  cvOriginalName  String?
  customFields    Json?

  // Search Index
  searchVector    String?         @db.Text

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  createdBy       String?

  jobApplications       JobApplication[]
  interviewSlots        InterviewSlot[]
  postSelectionRecords  PostSelectionRecord[]

  @@index([status])
  @@index([isPriority])
  @@fulltext([firstName, lastName])
  @@map("candidates")
}

model CandidateWorkHistory {
  id          String    @id @default(uuid())
  candidateId String
  company     String
  designation String
  startDate   DateTime?
  endDate     DateTime?
  isCurrent   Boolean   @default(false)
  description String?   @db.Text
  location    String?
  createdAt   DateTime  @default(now())

  @@index([candidateId])
  @@map("candidate_work_history")
}

// ============================================================
// CLIENTS
// ============================================================

model Client {
  id                String    @id @default(uuid())
  companyName       String
  contactPerson     String
  email             String
  phone             String
  alternatePhone    String?
  address           String?   @db.Text
  city              String?
  state             String?
  country           String?   @default("India")
  pincode           String?
  gstNumber         String?
  panNumber         String?
  industry          String?
  website           String?
  contractStartDate DateTime?
  contractEndDate   DateTime?
  isActive          Boolean   @default(true)
  notes             String?   @db.Text
  customFields      Json?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  createdBy         String?

  jobOpenings JobOpening[]
  invoices    Invoice[]

  @@index([isActive])
  @@map("clients")
}

// ============================================================
// JOB OPENINGS
// ============================================================

model JobOpening {
  id               String         @id @default(uuid())
  jobTitle         String
  clientId         String
  description      String?        @db.LongText
  requiredSkills   Json?
  preferredSkills  Json?
  experienceMin    Float?
  experienceMax    Float?
  salaryMin        Decimal?       @db.Decimal(12, 2)
  salaryMax        Decimal?       @db.Decimal(12, 2)
  jobType          EmploymentType @default(FULL_TIME)
  workLocation     String?
  workMode         String?
  numberOfOpenings Int            @default(1)
  status           JobStatus      @default(ACTIVE)
  priority         JobPriority    @default(MEDIUM)
  closingDate      DateTime?
  jdDocument       String?
  tags             Json?
  customFields     Json?
  createdBy        String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  client       Client          @relation(fields: [clientId], references: [id])
  creator      User?           @relation("CreatedByUser", fields: [createdBy], references: [id])
  assignees    User[]          @relation("AssignedToUser")
  applications JobApplication[]
  rounds       InterviewRound[]
  postSelectionRecords PostSelectionRecord[]

  @@index([status])
  @@index([priority])
  @@index([clientId])
  @@map("job_openings")
}

model JobApplication {
  id          String          @id @default(uuid())
  jobId       String
  candidateId String
  status      CandidateStatus @default(NEW)
  appliedAt   DateTime        @default(now())
  notes       String?         @db.Text
  updatedAt   DateTime        @updatedAt

  job       JobOpening @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidate Candidate  @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([jobId, candidateId])
  @@map("job_applications")
}

// ============================================================
// INTERVIEW ROUNDS
// ============================================================

model InterviewRound {
  id            String    @id @default(uuid())
  jobId         String
  roundNumber   Int
  roundName     String
  processGroup  String    @default("main")
  description   String?   @db.Text
  customColumns Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  job    JobOpening      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  slots  InterviewSlot[]

  @@unique([jobId, roundNumber, processGroup])
  @@map("interview_rounds")
}

model InterviewSlot {
  id            String          @id @default(uuid())
  roundId       String
  candidateId   String
  scheduledDate DateTime?
  scheduledTime String?
  status        InterviewStatus @default(SCHEDULED)
  result        RoundResult     @default(PENDING)
  feedback      String?         @db.Text
  remark        String?         @db.Text
  customFields  Json?
  interviewerIds Json?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  round     InterviewRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  candidate Candidate      @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("interview_slots")
}

// ============================================================
// INVOICES
// ============================================================

model Invoice {
  id              String        @id @default(uuid())
  invoiceNumber   String        @unique
  clientId        String
  invoiceDate     DateTime      @default(now())
  dueDate         DateTime?
  serviceDescription String?    @db.Text
  lineItems       Json?
  subtotal        Decimal       @db.Decimal(12, 2)
  gstType         String?
  cgstRate        Decimal?      @db.Decimal(5, 2)
  sgstRate        Decimal?      @db.Decimal(5, 2)
  igstRate        Decimal?      @db.Decimal(5, 2)
  cgstAmount      Decimal?      @db.Decimal(12, 2)
  sgstAmount      Decimal?      @db.Decimal(12, 2)
  igstAmount      Decimal?      @db.Decimal(12, 2)
  totalTax        Decimal?      @db.Decimal(12, 2)
  totalAmount     Decimal       @db.Decimal(12, 2)
  status          InvoiceStatus @default(DRAFT)
  paidAmount      Decimal?      @db.Decimal(12, 2)
  paidAt          DateTime?
  paymentMethod   String?
  paymentReference String?
  notes           String?       @db.Text
  pdfPath         String?
  createdBy       String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  client    Client @relation(fields: [clientId], references: [id])
  createdByUser User?  @relation("InvoiceCreatedBy", fields: [createdBy], references: [id])

  @@index([status])
  @@index([clientId])
  @@map("invoices")
}

// ============================================================
// DYNAMIC COLUMN DEFINITIONS
// ============================================================

model ColumnDefinition {
  id            String         @id @default(uuid())
  module        String
  name          String
  label         String
  dataType      ColumnDataType
  isVisible     Boolean        @default(true)
  isRequired    Boolean        @default(false)
  isSortable    Boolean        @default(true)
  isFilterable  Boolean        @default(true)
  isEditable    Boolean        @default(true)
  order         Int            @default(0)
  width         Int?
  config        Json?
  createdBy     String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([module, name])
  @@map("column_definitions")
}

// ============================================================
// THEME & SETTINGS
// ============================================================

model AppSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String?  @db.LongText
  category    String
  description String?
  updatedBy   String?
  updatedAt   DateTime @updatedAt

  @@map("app_settings")
}

// ============================================================
// AUDIT LOGS
// ============================================================

model AuditLog {
  id         String      @id @default(uuid())
  userId     String?
  userEmail  String?
  action     AuditAction
  module     String
  recordId   String?
  oldValues  Json?
  newValues  Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())

  user User? @relation("UserAuditLogs", fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([module])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String   @db.Text
  type      String
  isRead    Boolean  @default(false)
  data      Json?
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@map("notifications")
}

// ============================================================
// POST SELECTION RECORDS
// ============================================================

model PostSelectionRecord {
  id           String   @id @default(uuid())
  jobId        String
  candidateId  String
  processGroup String   @default("main")
  status       String   @default("PENDING")
  ctcOffered   Decimal? @db.Decimal(12, 2)
  offerLetters Json?
  customFields Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  job       JobOpening @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidate Candidate  @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([jobId, candidateId, processGroup])
  @@map("post_selection_records")
}
