# ============================================================
# HR RECRUITMENT SYSTEM - ENVIRONMENT CONFIGURATION
# ============================================================
# Copy this file to .env and fill in your actual values

# --- Server ---
NODE_ENV=development
PORT=5000
API_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173

# --- Database (XAMPP MySQL) ---
DATABASE_URL="mysql://root:@localhost:3306/hr_recruitment_db"

# --- JWT Authentication ---
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_jwt_key_change_this_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_SECRET=your_cookie_secret_key_min_32_chars

# --- OpenAI (for CV Bulk Import Parsing) ---
OPENAI_API_KEY=sk-your-openai-api-key-here

# --- Email (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_NAME=HR Recruitment System
SMTP_FROM_EMAIL=noreply@yourcompany.com

# --- Elasticsearch (for CV Search) ---
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_CV=hr_cvs
ELASTICSEARCH_INDEX_JOBS=hr_jobs

# --- File Upload ---
UPLOAD_MAX_SIZE_MB=10
UPLOAD_PATH=./uploads

# --- App Settings ---
APP_NAME=HR Recruitment System
APP_VERSION=1.0.0
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
